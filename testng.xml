<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Automation Suite">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="API Tests">
        <classes>
            <class name="api.AuthenticationTest"/>
            <class name="api.CreateEmployeeTest"/>
            <class name="api.EmployeeLifecycleTest"/>
            <class name="api.NegativeCasesTest"/>
        </classes>
    </test>

    <test name="UI Tests">
        <classes>
            <class name="ui.EmployeesUITest"/>
        </classes>
    </test>

</suite>
